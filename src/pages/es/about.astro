---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { ui } from '../../i18n';

const lang = 'es';
const copy = ui[lang];
---

<Base
  title={copy.meta.about.title}
  description={copy.meta.about.description}
  lang={lang}
>
  <Header activePage="about" lang={lang} />
  <main id="main-content">
    <section class="section">
      <div class="container">
        <p class="eyebrow">{copy.pages.about.eyebrow}</p>
        <h1 class="section-title" style="text-transform:none;font-weight:500;">
          {copy.pages.about.title}
        </h1>
        <p class="section-lead">
          {copy.pages.about.lead}
        </p>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Base>
