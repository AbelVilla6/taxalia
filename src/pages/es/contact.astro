---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { ui } from '../../i18n';

const lang = 'es';
const copy = ui[lang];
---

<Base
  title={copy.meta.contact.title}
  description={copy.meta.contact.description}
  lang={lang}
>
  <Header activePage="contact" lang={lang} />
  <main id="main-content">
    <section class="section-sm" style="background:var(--color-bg-soft);">
      <div class="container">
        <p class="eyebrow">{copy.pages.contact.eyebrow}</p>
        <h1 class="section-title" style="text-transform:none;font-weight:500;">{copy.pages.contact.title}</h1>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid grid-2" style="--grid-gap:4rem;align-items:start;">
          <div>
            <h2 class="section-title" style="font-size:1.8rem;text-transform:none;font-weight:500;margin-bottom:1.5rem;">
              {copy.pages.contact.consultation}
            </h2>
            <div class="form-group" style="display:grid;gap:1rem;">
              <div class="form-field">
                <label for="name" style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-primary-dark);display:block;margin-bottom:0.4rem;">
                  {copy.pages.contact.name}
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder={copy.pages.contact.namePlaceholder}
                  style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-surface);font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text);"
                />
              </div>
              <div class="form-field">
                <label for="email" style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-primary-dark);display:block;margin-bottom:0.4rem;">
                  {copy.pages.contact.email}
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder={copy.pages.contact.emailPlaceholder}
                  style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-surface);font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text);"
                />
              </div>
              <div class="form-field">
                <label for="message" style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-primary-dark);display:block;margin-bottom:0.4rem;">
                  {copy.pages.contact.message}
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  placeholder={copy.pages.contact.messagePlaceholder}
                  style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-surface);font-family:var(--font-body);font-size:var(--text-sm);color:var(--color-text);resize:vertical;"
                ></textarea>
              </div>
              <button type="submit" class="btn" style="align-self:flex-start;">
                {copy.pages.contact.send}
              </button>
            </div>
          </div>

          <div style="padding-top:3.5rem;">
            <CTA lang={lang} />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Base>
