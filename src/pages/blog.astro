---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Blog from '../components/Blog.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Blog — LB & CO Global Advisors"
  description="Insights, analysis, and expert perspectives from LB & CO Global Advisors."
>
  <Header activePage="Blog" />
  <main id="main-content">
    <section class="section-sm" style="background:var(--color-bg-soft);">
      <div class="container">
        <p class="eyebrow">From Our Blog</p>
        <h1 class="section-title" style="text-transform:none;font-weight:500;">Insights That Matter</h1>
      </div>
    </section>
    <Blog />
    <!-- TODO: Pagination, categories, search, individual post pages -->
  </main>
  <Footer />
</Base>
