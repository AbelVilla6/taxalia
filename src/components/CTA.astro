---
// CTA section — "Let's Work Together"
---

<section class="section-sm cta-section" aria-labelledby="cta-heading">
  <div class="container">
    <div class="cta-grid">
      <!-- Left: heading -->
      <div>
        <h2 id="cta-heading" class="section-title" style="text-transform:none;font-weight:500;font-size:clamp(1.8rem,3vw,3rem);">
          Let's Work Together
        </h2>
        <p class="section-lead" style="margin-top:0.5rem;font-size:var(--text-sm);">
          Have questions or ready to get started? We're here to help.
        </p>
      </div>

      <!-- Center: contact details -->
      <address class="cta-contact-list" style="font-style:normal;">
        <div class="cta-contact-item">
          <svg class="cta-contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.78a16 16 0 0 0 6.29 6.29l1.64-1.64a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <a href="tel:+18445550178">(844) 555-0178</a>
        </div>

        <div class="cta-contact-item">
          <svg class="cta-contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <a href="mailto:info@lbandcoglobaladvisors.com">info@lbandcoglobaladvisors.com</a>
        </div>

        <div class="cta-contact-item">
          <svg class="cta-contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span>Washington, DC 20005</span>
        </div>
      </address>

      <!-- Right: CTA button + social -->
      <div style="display:flex;flex-direction:column;gap:1rem;align-items:flex-start;">
        <a href="/contact" class="btn btn-outline">
          Get in Touch&nbsp;&nbsp;→
        </a>

        <a
          href="https://instagram.com/hitaxalia"
          class="cta-contact-item"
          style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.1em;text-transform:uppercase;"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="var(--color-primary)"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          Follow us&nbsp;
          <strong>@hitaxalia</strong>
        </a>
      </div>
    </div>
  </div>
</section>
