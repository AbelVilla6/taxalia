---
import {
  basePathFromPathname,
  languages,
  localizePath,
  ui,
  type Lang,
  type NavKey,
} from '../i18n';

export interface Props {
  activePage?: NavKey;
  lang?: Lang;
}

const { activePage, lang = 'en' } = Astro.props;
const copy = ui[lang].header;
const navLinks = [
  { key: 'about' as const, href: '/about' },
  { key: 'contact' as const, href: '/contact' },
  { key: 'services' as const, href: '/services' },
  { key: 'blog' as const, href: '/blog' },
].map((link) => ({
  ...link,
  href: localizePath(lang, link.href),
  label: copy.nav[link.key],
}));

const basePath = basePathFromPathname(Astro.url.pathname);
const languageLinks = [
  { lang: 'en' as const, href: localizePath('en', basePath) },
  { lang: 'es' as const, href: localizePath('es', basePath) },
];
---

<header class="site-header" role="banner">
  <nav class="navbar" aria-label={copy.navLabel}>
    <!-- Logo -->
    <a href={localizePath(lang, '/')} class="logo" aria-label={copy.homeLabel}>
      <span class="logo-square" aria-hidden="true">LB</span>
      <span class="logo-text-group">
        <span class="logo-name">LB &amp; CO</span>
        <span class="logo-tagline">Global Advisors</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-menu" role="list">
      {navLinks.map(({ key, href, label }) => (
        <li class="nav-item">
          <a
            href={href}
            class={`nav-link${activePage === key ? ' is-active' : ''}`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Actions -->
    <div class="nav-actions">
      <!-- Language switcher -->
      <div class="lang-switcher" role="group" aria-label={copy.languageSelector}>
        {languageLinks.map((languageLink) => (
          <a
            class={`lang-btn${lang === languageLink.lang ? ' active' : ''}`}
            href={languageLink.href}
            hreflang={languages[languageLink.lang].htmlLang}
            lang={languages[languageLink.lang].htmlLang}
            aria-label={copy.switchTo[languageLink.lang]}
            aria-current={lang === languageLink.lang ? 'true' : undefined}
          >
            {languages[languageLink.lang].label}
          </a>
        ))}
      </div>

      <a href={localizePath(lang, '/contact')} class="btn">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        {copy.book}
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="menu-toggle"
        aria-label={copy.openMenu}
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile drawer -->
<div id="mobile-drawer" class="drawer" role="dialog" aria-modal="true" aria-label={copy.mobileNavLabel}>
  <div class="drawer-inner">
    <div class="drawer-header">
      <span class="drawer-title">{copy.menu}</span>
      <button id="drawer-close" class="icon-btn" aria-label={copy.closeMenu}>&times;</button>
    </div>
    <nav aria-label={copy.mobileNavLabel}>
      <ul role="list" style="display:grid;gap:0.25rem;margin-top:1.5rem;">
        {navLinks.map(({ href, label }) => (
          <li>
            <a href={href} class="nav-link" style="padding-block:0.9rem;font-size:0.85rem;">
              {label}
            </a>
          </li>
        ))}
        <li style="margin-top:1rem;">
          <a href={localizePath(lang, '/contact')} class="btn" style="width:100%;justify-content:center;">
            {copy.book}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</div>
