# local dotfiles/directories (keep this file tracked)
.*
!.gitignore

# build output (frontend)
frontend/dist/
dist/                       # legacy tracked build noise; remove when clean
# generated types (frontend)
frontend/.astro/
.astro/                     # legacy generated types at root

# dependencies
frontend/node_modules/
backend/node_modules/
node_modules/               

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production
frontend/.env
backend/.env

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# backend
backend/dist/
backend/node_modules/
backend/coverage/
backend/.env
