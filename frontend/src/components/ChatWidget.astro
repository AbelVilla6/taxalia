---
import { localizePath, ui, type Lang } from '../i18n';

export interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const copy = ui[lang].chat;
---

<div id="chat-widget" class="chat-widget" role="complementary" aria-label={copy.ariaLabel}>
  <div class="chat-widget-header">
    <div class="chat-agent">
      <img
        class="chat-agent-avatar"
        src="/assets/images/agent-lexi.webp"
        alt={copy.imageAlt}
        width="40"
        height="40"
        loading="lazy"
        onerror="this.style.display='none'"
      />
      <div>
        <p class="chat-agent-name">Lexi</p>
        <p class="chat-agent-status">
          <span class="status-dot" aria-hidden="true"></span>
          {copy.status}
        </p>
      </div>
    </div>
    <button id="chat-close" class="chat-close" aria-label={copy.close}>&times;</button>
  </div>

  <div class="chat-widget-body">
    <p class="chat-bubble">{copy.bubble}</p>
    <a href={localizePath(lang, '/contact')} class="btn" style="width:100%;justify-content:center;">
      {copy.action}
    </a>
  </div>
</div>
