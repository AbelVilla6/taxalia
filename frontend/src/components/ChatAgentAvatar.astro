---
export interface Props {
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'eager' | 'lazy';
}

const {
  alt,
  class: className = 'chat-agent-avatar',
  width = 40,
  height = 40,
  loading = 'lazy',
} = Astro.props;
---

<img
  class={className}
  src="/assets/images/agent-lexi.webp"
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  onerror="this.style.display='none'"
/>
