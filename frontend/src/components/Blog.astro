---
import { localizePath, ui, type Lang } from '../i18n';

export interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const copy = ui[lang].blog;
---

<section class="section blog-lb" aria-labelledby="blog-heading">
  <div class="container">
    <!-- Header -->
    <div style="margin-bottom:0;">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2 id="blog-heading" class="section-title" style="text-transform:none;font-weight:500;">
        {copy.title}
      </h2>
    </div>

    <!-- Posts -->
    <div class="blog-grid-lb">
      {copy.posts.map((post) => (
        <article class="post-card-lb">
          <a href={localizePath(lang, post.href)} tabindex="-1" aria-hidden="true">
            <img
              class="post-image"
              src={post.image}
              alt={post.imageAlt}
              width="480"
              height="360"
              loading="lazy"
            />
          </a>
          <div>
            <p class="post-date">{post.date}</p>
            <h3 class="post-title">
              <a href={localizePath(lang, post.href)}>{post.title}</a>
            </h3>
            <p class="post-excerpt">{post.excerpt}</p>
            <a href={localizePath(lang, post.href)} class="link-arrow">{copy.readMore}</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
