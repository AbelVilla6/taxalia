---
import { localizePath, ui, type Lang } from '../i18n';

export interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const copy = ui[lang].hero;
---

<section class="hero-split" aria-label={copy.ariaLabel}>
  <!-- Left: content -->
  <div class="hero-split-content fade-up">
    <p class="hero-kicker" style="color:var(--color-primary);">{copy.kicker}</p>

    <h1 class="hero-split hero-title">
      {copy.title[0]}<br />
      {copy.title[1]}<br />
      {copy.title[2]}
    </h1>

    <p class="hero-text" style="margin-top:1.1rem;">
      {copy.text}
    </p>

    <div class="hero-actions">
      <a href={localizePath(lang, '/contact')} class="btn">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        {copy.book}
      </a>
      <a href={localizePath(lang, '/services')} class="btn btn-outline">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="9" y="9" width="13" height="13" rx="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        {copy.explore}
      </a>
    </div>

    <!-- Trust bar -->
    <div class="hero-trust">
      <span class="hero-trust-item">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        {copy.trustLocation}
      </span>
      <span style="color:var(--color-border)">|</span>
      <span class="hero-trust-item">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
        {copy.trustValues}
      </span>
    </div>
  </div>

  <!-- Right: photo -->
  <div class="hero-split-media">
    <img
      src="/assets/images/hero-advisory.webp"
      alt={copy.imageAlt}
      width="960"
      height="1080"
      loading="eager"
      fetchpriority="high"
    />
  </div>
</section>
