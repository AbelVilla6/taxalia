---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Blog from '../components/Blog.astro';
import Footer from '../components/Footer.astro';
import { ui } from '../i18n';

const lang = 'en';
const copy = ui[lang];
---

<Base
  title={copy.meta.blog.title}
  description={copy.meta.blog.description}
  lang={lang}
>
  <Header activePage="blog" lang={lang} />
  <main id="main-content">
    <section class="section-sm" style="background:var(--color-bg-soft);">
      <div class="container">
        <p class="eyebrow">{copy.blog.eyebrow}</p>
        <h1 class="section-title" style="text-transform:none;font-weight:500;">{copy.blog.title}</h1>
      </div>
    </section>
    <Blog lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
