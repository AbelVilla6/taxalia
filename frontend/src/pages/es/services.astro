---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Services from '../../components/Services.astro';
import Footer from '../../components/Footer.astro';
import { ui } from '../../i18n';

const lang = 'es';
const copy = ui[lang];
---

<Base
  title={copy.meta.services.title}
  description={copy.meta.services.description}
  lang={lang}
>
  <Header activePage="services" lang={lang} />
  <main id="main-content">
    <section class="section-sm" style="background:var(--color-bg-soft);">
      <div class="container">
        <p class="eyebrow">{copy.services.pageEyebrow}</p>
        <h1 class="section-title" style="text-transform:none;font-weight:500;">{copy.services.pageTitle}</h1>
      </div>
    </section>
    <Services lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
